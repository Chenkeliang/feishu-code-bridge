{
  "name": "feishu-code-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "飞书码桥 — 用飞书远程驱动本机 Cursor / Claude / Codex 写代码",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @feishu-code-bridge/bridge dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acp-probe": "node scripts/acp-probe.mjs",
    "lint": "tsc -b",
    "doctor": "node apps/bridge/dist/cli.js doctor",
    "start": "node apps/bridge/dist/cli.js start",
    "runner": "node packages/runner-host/dist/cli.js",
    "start:all": "bash scripts/start.sh",
    "setup": "bash scripts/start.sh setup"
  },
  "bin": {
    "feishu-code-bridge": "./apps/bridge/dist/cli.js",
    "feishu-code-runner": "./packages/runner-host/dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
